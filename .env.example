# Required
# Use a Neon Postgres connection string. Get one at https://console.neon.tech
# by creating a project, then copying the "Connection string" from the
# dashboard. Pooled URLs end with `-pooler` in the host and are recommended
# for serverless/edge usage; either pooled or direct works for local dev.
DATABASE_URL=postgres://USER:PASSWORD@ep-your-neon-host.neon.tech/dashboard?sslmode=require

DASHBOARD_PASSWORD=changeme
SHARE_LINK_SIGNING_KEY=replace-with-32-byte-random-hex
SESSION_COOKIE_SECRET=replace-with-32-byte-random-hex

# Optional (per-module)
# JOB_TRACKER_OPENAI_KEY=
